{
  "schema": 1,
  "description": "現在のゲーム状態に応じた問題・事件を生成する",
  "execution_settings": {
    "default": {
      "max_tokens": 400,
      "temperature": 0.8
    }
  },
  "input_variables": [
    {
      "name": "setting",
      "description": "ゲームの舞台設定",
      "default": ""
    },
    {
      "name": "storySummary",
      "description": "これまでのあらすじ",
      "default": "（まだなし）"
    },
    {
      "name": "round",
      "description": "現在のラウンド番号",
      "default": "1"
    },
    {
      "name": "successCount",
      "description": "成功回数",
      "default": "0"
    },
    {
      "name": "failureCount",
      "description": "失敗回数",
      "default": "0"
    }
  ]
}